{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "src/view/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "src/**", "use": "@vercel/static" },
    { "src": "templates/**", "use": "@vercel/static" },
    { "src": "static/**", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ], 
  
  "routes": [
    { "src": "^/css/(.*)$", "dest": "/css/$1" },
    { "src": "^/src/(.*)$", "dest": "/src/$1" },
    { "src": "^/templates/(.*)$", "dest": "/templates/$1" },
    { "src": "^/static/(.*)$", "dest": "/static/$1" },
    { "src": "^/public/(.*)$", "dest": "/public/$1" },
    { "src": "^/(.*\\.(js|css|png|jpg|jpeg|svg|ico|json))$", "dest": "/$1" },
    { "src": "^/$", "dest": "/templates/static/html/login.html" },
    { "src": "^/dashboard$", "dest": "/templates/static/html/dashboard.html" },
    { "src": "^/login$", "dest": "/templates/static/html/login.html" },
    { "src": "^/criar-perfil$", "dest": "/templates/static/html/criar_perfil.html" },
    { "src": "^/templates/static/html/login.html$", "dest": "/templates/static/html/login.html" },
    { "src": "^/templates/static/html/criar-perfil.html$", "dest": "/templates/static/html/criar_perfil.html" },
    { "src": "^/templates/static/view/dashboard.html$", "dest": "/templates/static/html/dashboard.html" },
    { "src": "^/(.*)$", "dest": "/templates/static/html/login.html" }
  ]
}